    {
      "id": "ZFW5TSSA61jAJ4cH7uywJ",
      "type": "text",
      "x": 1437,
      "y": 660,
      "width": 903.6333618164062,
      "height": 200,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "af",
      "roundness": null,
      "seed": 1082455705,
      "version": 459,
      "versionNonce": 961009719,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1747297585533,
      "link": null,
      "locked": false,
      "text": "ROUTES\n\npost /games/create -> creates a new empty game with poster user as admin, returns gameId\npost /games/{gameId}/invite -> uploads one player data as json, sends invite if necessary\n    - could be called by admins or normal users if anyLocals is on\npost /games/{gameId}/uninvite -> uninvites a player\npost /games/{gameId}/anyLocals -> sets anyLocals setting\npost /games/{gameId}/start -> starts the game",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "ROUTES\n\npost /games/create -> creates a new empty game with poster user as admin, returns gameId\npost /games/{gameId}/invite -> uploads one player data as json, sends invite if necessary\n    - could be called by admins or normal users if anyLocals is on\npost /games/{gameId}/uninvite -> uninvites a player\npost /games/{gameId}/anyLocals -> sets anyLocals setting\npost /games/{gameId}/start -> starts the game",
      "autoResize": true,
      "lineHeight": 1.25
    },
