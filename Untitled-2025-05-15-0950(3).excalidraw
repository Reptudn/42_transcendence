    {
      "id": "g1ZXnOOszpaG6VPE2jaxU",
      "type": "text",
      "x": 448,
      "y": 1692,
      "width": 990.6333618164062,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aV",
      "roundness": null,
      "seed": 1506513081,
      "version": 313,
      "versionNonce": 1525641785,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1747295868869,
      "link": null,
      "locked": false,
      "text": "if allow friends to add local players checkbox is toggled, its immediately sent to the server.\n\nif no, all non-admin locals are removed and that info is sent to the friends, their + button is removed\nif yes, friends get the plus button and may now add players",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "if allow friends to add local players checkbox is toggled, its immediately sent to the server.\n\nif no, all non-admin locals are removed and that info is sent to the friends, their + button is removed\nif yes, friends get the plus button and may now add players",
      "autoResize": true,
      "lineHeight": 1.25
    },
